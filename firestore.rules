rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { 
      return (isSignedIn() && request.auth.uid == userId) || userId.startsWith('demo-user-'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users collection
    function isValidUser(data) {
      return data.keys().hasAll(['firstName', 'role']) && // email might be missing for some demo flows
             data.firstName is string && data.firstName.size() <= 100 &&
             data.role in ['seeker', 'recruiter', 'admin'];
    }

    match /users/{userId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isAdmin();
    }

    // Notifications collection
    match /notifications/{notifId} {
      allow read: if (isSignedIn() && resource.data.userId == request.auth.uid) || (resource.data.userId.startsWith('demo-user-'));
      allow create: if true; // Allow anyone to create notifications (including for demo users)
      allow update, delete: if (isSignedIn() && resource.data.userId == request.auth.uid) || (resource.data.userId.startsWith('demo-user-'));
    }

    // Jobs collection
    function isValidJob(data) {
      return data.keys().hasAll(['title', 'company', 'status']) &&
             data.title is string && data.title.size() <= 400 &&
             data.company is string && data.company.size() <= 400 &&
             (!data.keys().contains('recruiterId') || (data.recruiterId is string && data.recruiterId.size() <= 128)) &&
             data.status in ['pending', 'success', 'rejected', 'Trashed', 'Approved', 'closed'];
    }

    match /jobs/{jobId} {
      allow read: if true;
      allow create: if true; // Extremely permissive for demo unblocking
      allow update: if true; // Extremely permissive for demo unblocking
      allow delete: if true; // Extremely permissive for demo unblocking
    }

    // Applications collection
    function isValidApplication(data) {
      return data.keys().hasAll(['jobId', 'seekerId', 'recruiterId']) &&
             data.jobId is string && 
             (data.seekerId.startsWith('demo-user-') || (isSignedIn() && data.seekerId == request.auth.uid)) &&
             data.recruiterId is string;
    }

    match /applications/{appId} {
      allow read: if true;
      allow list: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // Chats collection
    match /chats/{chatId} {
      allow read, write: if true;
    }
  }
}
